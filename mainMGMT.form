    private void btnAddActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnAddActionPerformed
 int id = Integer.parseInt(txtCustomerId.getText());
    String name = txtName.getText();
    String phone = txtPhone.getText();
    String address = txtAddress.getText();

   Customer.addCustomerDB(id, name, phone, address);
   loadTable();
JOptionPane.showMessageDialog(this, "Customer added successfully");
        // TODO add your handling code here:
    }//GEN-LAST:event_btnAddActionPerformed

    private void btnSearchActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchActionPerformed
                                       
    int id = Integer.parseInt(txtCustomerId.getText());
    Customer c = Customer.getCustomerByIdDB(id);

   if (c != null) {
    txtName.setText(c.getName());
    txtPhone.setText(c.getPhone());
    txtAddress.setText(c.getAddress());
} else {
    JOptionPane.showMessageDialog(this, "Customer not found in database");
}
    // TODO add your handling code here:
    }//GEN-LAST:event_btnSearchActionPerformed

    private void btnUpdateActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateActionPerformed
int id = Integer.parseInt(txtCustomerId.getText());
    String name = txtName.getText();
    String phone = txtPhone.getText();
    String address = txtAddress.getText();

   Customer.updateCustomerDB(id, name, phone, address);
   loadTable();
JOptionPane.showMessageDialog(this, "Customer updated successfully");
      // TODO add your handling code here:
    }//GEN-LAST:event_btnUpdateActionPerformed

    private void btnDeleteActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnDeleteActionPerformed
 int id = Integer.parseInt(txtCustomerId.getText());

   Customer.deleteCustomerDB(id);
   loadTable();
JOptionPane.showMessageDialog(this, "Customer deleted successfully ");
    // TODO add your handling code here:
    }//GEN-LAST:event_btnDeleteActionPerformed

  private void loadTable() {
    javax.swing.table.DefaultTableModel model =
        (javax.swing.table.DefaultTableModel) jTable1.getModel();

    model.setRowCount(0);

    for (Customer c : Customer.getAllCustomersDB()) {
        model.addRow(new Object[]{
            c.getCustomerId(),
            c.getName(),
            c.getPhone(),
            c.getAddress()
        });
    }
}

