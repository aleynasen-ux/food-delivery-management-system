    private void btnAdd1ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnAdd1ActionPerformed
         int orderId = Integer.parseInt(txtOrderId.getText());
int customerId = Integer.parseInt(txtCustomerId.getText());
String date = txtOrderDate.getText();

Order.addOrderDB(orderId, customerId, date);
loadTable();
JOptionPane.showMessageDialog(this, "Order added successfully");
   // TODO add your handling code here:
    }//GEN-LAST:event_btnAdd1ActionPerformed

    private void btnUpdateActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateActionPerformed
 int orderId = Integer.parseInt(txtOrderId.getText());
int customerId = Integer.parseInt(txtCustomerId.getText());
String date = txtOrderDate.getText();

Order.updateOrderDB(orderId, customerId, date);
loadTable();
JOptionPane.showMessageDialog(this, "Order updated successfully");
  // TODO add your handling code here:
    }//GEN-LAST:event_btnUpdateActionPerformed

    private void btnDelete1ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnDelete1ActionPerformed
      int orderId = Integer.parseInt(txtOrderId.getText());

Order.deleteOrderDB(orderId);
loadTable();
JOptionPane.showMessageDialog(this, "Order deleted successfully");
  // TODO add your handling code here:
    }//GEN-LAST:event_btnDelete1ActionPerformed

    private void btnSearchActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchActionPerformed
int orderId = Integer.parseInt(txtOrderId.getText());
Order o = Order.getOrderByIdDB(orderId);

if (o != null) {
    txtCustomerId.setText(String.valueOf(o.getCustomerId()));
    txtOrderDate.setText(o.getOrderDate());
} else {
    JOptionPane.showMessageDialog(this, "Order not found");
}
  // TODO add your handling code here:
    }//GEN-LAST:event_btnSearchActionPerformed
private void loadTable() {
    javax.swing.table.DefaultTableModel model =
        (javax.swing.table.DefaultTableModel) jTable1.getModel();

    model.setRowCount(0);

    for (Order o : Order.getAllOrdersDB()) {
        model.addRow(new Object[]{
            o.getOrderId(),
            o.getCustomerId(),
            o.getOrderDate()
        });
    }
}

